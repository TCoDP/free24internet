# NextAuth (обязательно в production)
AUTH_SECRET=
# Публичный URL сайта (для callback и cookies)
AUTH_URL=https://free24internet.vip

# Совместимость с v4 (опционально, дублирует AUTH_*)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# MySQL на том же сервере, что и Next.js (с ПК подключайтесь к публичному IP сервера; HOST здесь оставьте 127.0.0.1)
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
