# NextAuth (обязательно в production)
AUTH_SECRET=
# Публичный URL сайта (для callback и cookies). Без www, если сайт на apex-домене.
AUTH_URL=https://free24internet.vip

# Совместимость с v4 (опционально, дублирует AUTH_*)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# Вызов из бота после оплаты: POST /api/internal/subscription-grant, заголовок X-Subscription-Grant-Secret
SUBSCRIPTION_GRANT_SECRET=

# Moneta / PayAnyWay (оплата на сайте через MONETA.Assistant). Кнопка оплаты только у пользователей с users.is_their = 1.
# В личном кабинете Moneta укажите Pay URL: https://<ваш-домен>/api/webhooks/moneta (GET и POST).
MONETA_ACCOUNT_ID=
MONETA_SECRET=
# 1 = demo.moneta.ru, 0 = production moneta.ru
MONETA_DEMO=1
# Как показывать магазин в описании платежа (MNT_DESCRIPTION). Если пусто — берётся домен из AUTH_URL / SITE_ORIGIN.
# MONETA_STORE_NAME=Свободный Интернет

# MySQL на том же сервере, что и Next.js (с ПК подключайтесь к публичному IP сервера; HOST здесь оставьте 127.0.0.1)
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
