# Скопируйте в .env в этой же папке: cp .env.example .env  (Windows: copy .env.example .env)

BOT_TOKEN=
PANEL_URL=https://127.0.0.1:2053/your_inbound_path
PANEL_USER=root
PANEL_PASS=
# Опционально, LoginSecret в 3X-UI
PANEL_SECRET=

# Telegram user id админа (0 = без уведомлений о тикетах)
ADMIN_ID=0

DB_HOST=127.0.0.1
DB_USER=
DB_PASS=
DB_NAME=vpn_bot
# Таблицы pricing_global / pricing_plan_terms (как на сайте). Если пусто — используется DB_NAME.
# PRICING_DB_NAME=free24internet

# Оплата картой / СБП как на сайте (Moneta). На сервере в .env сайта: BOT_PAYMENT_SESSION_SECRET (то же значение, что BOT_PAYMENT_SECRET)
# Бот и сайт — одна БД (DB_* = MYSQL_* сайта). Пополнение balance: вебхук Moneta на сайте пишет в users.balance (миграция 015).
# SITE_API_BASE=https://free24internet.vip
# BOT_PAYMENT_SECRET=

START_PORT=20000
VPN_DOMAIN=example.com
