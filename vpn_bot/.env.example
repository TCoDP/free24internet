# Скопируйте в .env в этой же папке: cp .env.example .env  (Windows: copy .env.example .env)

BOT_TOKEN=
# Username бота без @ — ссылки «пригласить друга» (t.me/…?start=ref_КОД), как TELEGRAM_BOT_USERNAME на сайте
# TELEGRAM_BOT_USERNAME=
PANEL_URL=https://127.0.0.1:2053/your_inbound_path
PANEL_USER=root
PANEL_PASS=
# Опционально, LoginSecret в 3X-UI
PANEL_SECRET=

# Telegram user id админа (0 = без уведомлений о тикетах)
ADMIN_ID=0

DB_HOST=127.0.0.1
DB_USER=
DB_PASS=
DB_NAME=vpn_bot
# Таблицы pricing_global / pricing_plan_terms (как на сайте). Если пусто — используется DB_NAME.
# PRICING_DB_NAME=free24internet

# Оплата через сайт (Laravel): Moneta и/или Platega.io. На сервере: BOT_PAYMENT_SESSION_SECRET = BOT_PAYMENT_SECRET бота.
# В кабинете Platega укажите callback URL: https://<ваш-домен>/api/webhooks/platega
# Бот и сайт — одна БД (DB_* = MYSQL_* сайта). Пополнение balance: вебхуки Moneta/Platega на сайте пишут в users.balance.
# SITE_API_BASE=https://free24internet.vip
# BOT_PAYMENT_SECRET=
#
# Регистрация для сайта из бота (/register): POST /api/internal/bot-register с тем же секретом.
# Ссылки VPN/QR «как в кабинете» (подписка https://…/sub/…): POST /api/internal/bot-vpn-display — те же SITE_API_BASE и BOT_PAYMENT_SECRET.

# Один общий VLESS+Reality inbound: все клиенты на этом порту (до N человек).
SHARED_VLESS_PORT=20000
SHARED_INBOUND_REMARK=Shared_VLESS
SHARED_INBOUND_MAX_CLIENTS=100
# Совместимость: если SHARED_VLESS_PORT не задан в старых .env, можно оставить START_PORT как запасной дефолт в config.py
START_PORT=20000
VPN_DOMAIN=example.com
