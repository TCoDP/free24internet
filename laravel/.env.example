APP_NAME=Free24Internet
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=https://free24internet.vip

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vpn_bot
DB_USERNAME=vpn_user
DB_PASSWORD=

# Тесты: в phpunit.xml — DB_DATABASE=vpn_bot_test. Один раз: создайте схему и выполните php artisan migrate (без migrate:fresh в тестах).
# Feature-тесты в транзакциях (DatabaseTransactions) — данные после прогона откатываются, таблицы не удаляются.
# ALLOW_DESTRUCTIVE_TESTS_ON_PRIMARY_DB=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=free24internet.vip,localhost,127.0.0.1
SESSION_COOKIE=free24internet_session

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Почта: локально удобно log; в проде — smtp (RuWeb и т.п., порт 587) или Mailtrap Sending API.
MAIL_MAILER=log
# Mailtrap (Symfony Mailer + SDK): https://github.com/mailtrap/mailtrap-php/tree/main/src/Bridge/Laravel
# MAIL_MAILER=mailtrap-sdk
# Транзакционная отправка (по умолчанию):
# MAILTRAP_HOST=send.api.mailtrap.io
# Песочница (Email Testing):
# MAILTRAP_HOST=sandbox.api.mailtrap.io
# MAILTRAP_INBOX_ID=
# Токен API: https://mailtrap.io/api-tokens
# MAILTRAP_API_KEY=
# MAIL_MAILER=smtp
# Схема: null = авто (465 → smtps, иначе smtp + STARTTLS на 587).
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# HELO/EHLO: лучше совпадать с публичным доменом сайта (и с PTR при прямой отправке).
MAIL_EHLO_DOMAIN=free24internet.vip
MAIL_FROM_ADDRESS="noreply@free24internet.vip"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=https://free24internet.vip

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# URL для возврата после оплаты (в продакшене совпадает с публичным доменом кабинета)
AUTH_URL="${APP_URL}"

# Токен Telegram-бота для системных уведомлений (тот же, что BOT_TOKEN в vpn_bot/.env)
TELEGRAM_BOT_TOKEN=

# Username бота без @ — для ссылок «Привязать Telegram» (t.me/username?start=link_…)
TELEGRAM_BOT_USERNAME=

# Напоминания об окончании подписки / пробного периода (уведомление в ЛК + сообщение в Telegram).
# Нужен cron: * * * * * php artisan schedule:run
SUBSCRIPTION_EXPIRY_REMINDERS_ENABLED=true
# За сколько календарных дней до даты окончания (в APP_TIMEZONE), через запятую
SUBSCRIPTION_EXPIRY_REMINDER_DAYS=7,3,1

# Пробный VPN с сайта: прямой доступ к панели 3X-UI (как PANEL_* в vpn_bot/.env, без вызова бота)
VPN_PANEL_URL=
VPN_PANEL_USER=
VPN_PANEL_PASSWORD=
# VPN_PANEL_SECRET=
# Общий inbound: один порт на всех (как SHARED_VLESS_PORT / SHARED_INBOUND_REMARK у бота)
VPN_SHARED_VLESS_PORT=20000
VPN_SHARED_INBOUND_REMARK=Shared_VLESS
VPN_SHARED_INBOUND_MAX_CLIENTS=100
# VPN_START_PORT=20000  (fallback для VPN_SHARED_VLESS_PORT, если не задан)

# Домен/IP в vless-ссылке в кабинете (как VPN_DOMAIN в vpn_bot/.env)
VPN_DOMAIN=free24internet.vip
# Имя подписки в клиентах для /sub/… (заголовки). По умолчанию: Free24Internet
# VPN_SUBSCRIPTION_IMPORT_PROFILE=Free24Internet
# Ссылка на сайт (заголовок Profile-Web-Page-Url у /sub/… и блок в кабинете). Пусто = берётся APP_URL из этого же .env
# VPN_SUBSCRIPTION_PROFILE_WEB_URL=https://free24internet.vip
# Подпись узла в VLESS (#…), UTF-8. По умолчанию: флаг NL + «Нидерланды»
# VPN_VLESS_DISPLAY_NAME=

# Секрет для API бота: тот же, что BOT_PAYMENT_SECRET в vpn_bot (оплаты + регистрация из бота POST /api/internal/bot-register)
BOT_PAYMENT_SESSION_SECRET=

# Суммы пополнения баланса (руб.), через запятую — сайт, бот и API capabilities
# BALANCE_TOPUP_AMOUNTS_RUB=100,300,500,1000,3000

# Moneta (опционально; на сайте и в боте только для пользователей с is_their)
MONETA_ACCOUNT_ID=
MONETA_SECRET=
MONETA_STORE_NAME="Your store"
MONETA_DEMO=0

# Platega.io — https://docs.platega.io/ (доступна всем пользователям с привязанным Telegram)
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=
# 2=СБП QR, 3=ЕРИП, 11=карты, 12=международная, 13=крипто
PLATEGA_PAYMENT_METHOD=2
# Отдельная кнопка оплаты криптой (метод 13), пока основной способ не крипта
PLATEGA_ENABLE_CRYPTO=true
PLATEGA_API_BASE=https://app.platega.io
